{
  "framework": null,
  "buildCommand": "npm run build:all",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/andorra/:path*",         "destination": "/andorra/index.html" },
    { "source": "/transit-builder/:path*", "destination": "/transit-builder/index.html" },
    { "source": "/:path*",                 "destination": "/index.html" }
  ]
}
